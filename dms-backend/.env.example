# MongoDB Connection String
MONGO_URI=mongodb://your_db_user:your_db_password@your_cluster.mongodb.net/DMS_Database?ssl=true&authSource=admin&retryWrites=true&w=majority

# Server Port
PORT=5000

# Email configuration for sending emails (e.g. Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# OpenAI API Key for AI features
OPENAI_API_KEY=your_openai_api_key
